# Phantom — environment variable reference
# Copy this file to .env and fill in real values.
# .env is gitignored; never commit real secrets.

# ── AI / LLM providers ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Agent configuration ────────────────────────────────────────────────────────
PHANTOM_AGENT_MODEL=claude-opus-4-5

# ── Vision / multi-modal ──────────────────────────────────────────────────────
PHANTOM_VISION_API_KEY=

# ── Phantom Hub (federation) ──────────────────────────────────────────────────
PHANTOM_HUB_URL=https://hub.phantom.dev
HUB_JWT_SECRET=
HUB_API_KEYS=

# ── GitHub integration ────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GH_REPO=owner/repo

# ── Ollama (local LLM) ────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Phantom runtime flags ─────────────────────────────────────────────────────
# Set to 1 to skip bundle-store / keychain initialisation during dev
PHANTOM_DISABLE_BUNDLE_STORE=
# Override where Phantom stores its home directory
PHANTOM_HOME=
# MCP Unix socket path
PHANTOM_MCP_SOCK=
# Identity namespace for federation
PHANTOM_IDENTITY_NAMESPACE=

# ── Piper TTS ─────────────────────────────────────────────────────────────────
PIPER_MODEL=

# ── Hub tuning ────────────────────────────────────────────────────────────────
HUB_FORWARD_TIMEOUT_SECS=30
